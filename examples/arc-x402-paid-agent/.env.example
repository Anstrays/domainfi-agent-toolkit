# Arc paid-agent deployment example.
# Copy to your deployment provider's secret/env UI; do not commit real values.

# Run the seller endpoint against a real Circle Gateway/x402 verifier.
DOMAINFI_PAYMENT_MODE=gateway
CIRCLE_GATEWAY_URL=https://gateway.example.test/v1
CIRCLE_GATEWAY_API_KEY=redacted
CIRCLE_GATEWAY_TIMEOUT=20

# HTTP bind settings for examples/arc-x402-paid-agent/server.py.
# Most platforms inject PORT. Keep HOST at 0.0.0.0 only inside a managed deployment.
HOST=0.0.0.0
PORT=8765

# Live smoke-test target. ARC_LIVE_X_PAYMENT must be an opaque proof created
# by the real buyer/Gateway flow; the repository never generates or stores it.
ARC_PAID_AGENT_URL=https://paid-agent.example.test
ARC_PAID_AGENT_PATH=/scan
ARC_LIVE_X_PAYMENT=redacted
ARC_LIVE_SMOKE_TIMEOUT=20
